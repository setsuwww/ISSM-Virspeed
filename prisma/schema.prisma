generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LogAction {
  VIEW
  SUBMIT
  CREATE
  UPDATE
  DELETE
}

enum LogMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum SecurityAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  SESSION_REVOKED
  ROLE_CHANGED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SESSION_CLEARED
}

enum Role {
  ADMIN
  EMPLOYEE
  USER
}

enum ShiftType {
  OFF
  MORNING
  AFTERNOON
  EVENING
  CUSTOM
}

enum LocationType {
  WFO
  WFA
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum FrequencyType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  ONCE
}

enum ApprovalStatus {
  PENDING
  PENDING_TARGET
  PENDING_ADMIN
  APPROVED
  REJECTED
}

enum LeaveCategory {
  ANNUAL
  SICK
  MATERNITY
  MARRIAGE
  BEREAVEMENT
  RELIGIOUS
  SPECIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PERMISSION
  ALPHA
  INACTIVE
}

model ActivityLog {
  id        Int       @id @default(autoincrement())
  userId    String
  url       String
  action    LogAction
  method    LogMethod
  data      Json?
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([action])
}

model SecurityLog {
  id        String         @id @default(uuid())
  userId    String
  action    SecurityAction
  ip        String?
  userAgent String?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SuspiciousActivity {
  id        String   @id @default(uuid())
  userId    String?
  ip        String?
  reason    String
  score     Int
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resolved])
}

model SystemConfig {
  id           Int      @id @default(autoincrement())
  allWfaActive Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  password     String
  role         Role    @default(USER)
  isLocked     Boolean @default(false)
  isFlagged    Boolean @default(false)
  tokenVersion Int     @default(0)

  locationId Int?
  shiftId    Int?

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  shift    Shift?    @relation("ShiftUsers", fields: [shiftId], references: [id])

  schedules           SchedulesOnUsers[]
  reminders           ScheduleReminder[]
  passwordResetTokens PasswordResetToken[]
  attendances         Attendance[]

  earlyCheckoutRequests EarlyCheckoutRequest[]
  shiftRequests         ShiftChangeRequest[]   @relation("RequestedUser")
  createdRequests       ShiftChangeRequest[]   @relation("RequestedByAdmin")
  targetShiftRequests   ShiftChangeRequest[]   @relation("TargetUser")

  leaveBalances  UserLeaveBalance[]
  leaveRequests  LeaveRequest[]
  approvedLeaves LeaveRequest[]     @relation("LeaveApprovedBy")

  activityLogs         ActivityLog[]
  securityLogs         SecurityLog[]
  suspiciousActivities SuspiciousActivity[]

  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserLeaveBalance {
  userId      String
  leaveTypeId Int
  year        Int

  totalDays Int
  usedDays  Int @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, leaveTypeId, year])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Schedule {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  frequency   FrequencyType @default(ONCE)
  startDate   DateTime?
  startTime   String?
  endDate     DateTime?
  endTime     String?
  locationId  Int?
  isActive    Boolean       @default(true)

  location  Location?          @relation(fields: [locationId], references: [id])
  users     SchedulesOnUsers[]
  reminders ScheduleReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchedulesOnUsers {
  id         Int    @id @default(autoincrement())
  scheduleId Int
  userId     String

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}

model ScheduleReminder {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  userId     String
  remindAt   DateTime
  createdAt  DateTime @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}

model Location {
  id        Int            @id @default(autoincrement())
  name      String
  location  String?
  longitude Float?
  latitude  Float?
  radius    Float?
  type      LocationType   @default(WFO)
  status    LocationStatus @default(INACTIVE)
  startTime Int?
  endTime   Int?
  parentId  Int?
  parent    Location?      @relation("LocationHierarchy", fields: [parentId], references: [id])
  branches  Location[]     @relation("LocationHierarchy")

  users     User[]
  shifts    Shift[]
  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id        Int       @id @default(autoincrement())
  name      String
  type      ShiftType
  startTime Int
  endTime   Int
  isActive  Boolean   @default(true)

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id])

  users       User[]       @relation("ShiftUsers")
  attendances Attendance[]

  oldShiftRequests    ShiftChangeRequest[] @relation("OldShift")
  newShiftRequests    ShiftChangeRequest[] @relation("NewShift")
  targetShiftRequests ShiftChangeRequest[] @relation("TargetShift")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id                  Int              @id @default(autoincrement())
  date                DateTime
  status              AttendanceStatus @default(ABSENT)
  approval            ApprovalStatus?
  reason              String?
  adminReason         String?
  checkInTime         DateTime?
  checkOutTime        DateTime?
  workMinutes         Int?
  earlyCheckoutReason String?
  userId              String
  shiftId             Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  earlyCheckoutRequests EarlyCheckoutRequest[]
  locationType          LocationType?
  locationStatus        LocationStatus?

  @@unique([userId, shiftId, date])
  @@index([userId, date])
}

model EarlyCheckoutRequest {
  id Int @id @default(autoincrement())

  userId       String
  attendanceId Int?

  reason      String
  status      ApprovalStatus @default(PENDING)
  adminReason String?

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([attendanceId])
}

model LeaveType {
  id       Int           @id @default(autoincrement())
  code     String        @unique
  name     String
  category LeaveCategory
  maxDays  Int

  leaveRequests LeaveRequest[]
  balances      UserLeaveBalance[]
}

model LeaveRequest {
  id Int @id @default(autoincrement())

  userId      String
  leaveTypeId Int

  startDate DateTime
  endDate   DateTime
  totalDays Int

  reason      String?
  adminReason String?
  status      ApprovalStatus @default(PENDING)

  approvedById String?
  approvedBy   User?   @relation("LeaveApprovedBy", fields: [approvedById], references: [id])

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([leaveTypeId])
}

model ShiftChangeRequest {
  id Int @id @default(autoincrement())

  user   User   @relation("RequestedUser", fields: [userId], references: [id], onDelete: Cascade)
  userId String

  requestedBy   User   @relation("RequestedByAdmin", fields: [requestedById], references: [id])
  requestedById String

  targetUser   User?   @relation("TargetUser", fields: [targetUserId], references: [id])
  targetUserId String?

  oldShift   Shift? @relation("OldShift", fields: [oldShiftId], references: [id])
  oldShiftId Int?

  newShift   Shift? @relation("NewShift", fields: [newShiftId], references: [id])
  newShiftId Int?

  targetShift   Shift? @relation("TargetShift", fields: [targetShiftId], references: [id])
  targetShiftId Int?

  reason       String
  rejectReason String?
  startDate    DateTime
  endDate      DateTime?
  status       ApprovalStatus @default(PENDING_TARGET)

  verifiedByTarget Boolean @default(false)
  verifiedByAdmin  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
